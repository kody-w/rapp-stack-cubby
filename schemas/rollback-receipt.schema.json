{
  "$defs": {
    "absolute_path": {
      "pattern": "^/",
      "type": "string"
    },
    "rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,62}:[0-9a-f]{64}$",
      "type": "string"
    },
    "tag": {
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[1-9][0-9]*)?$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:private-demo-live-receipt:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "controller": {
      "additionalProperties": false,
      "properties": {
        "python": {"$ref": "#/$defs/absolute_path"},
        "rappid": {"$ref": "#/$defs/rappid"},
        "root": {"$ref": "#/$defs/absolute_path"},
        "token_file": {"$ref": "#/$defs/absolute_path"},
        "url": {
          "pattern": "^http://(?:127\\.0\\.0\\.1|\\[::1\\]):[0-9]+(?:/chat)?$",
          "type": "string"
        }
      },
      "required": ["python", "url", "token_file", "rappid", "root"],
      "type": "object"
    },
    "imessage": {
      "additionalProperties": false,
      "properties": {
        "config": {"$ref": "#/$defs/absolute_path"},
        "plist": {"$ref": "#/$defs/absolute_path"},
        "tools_root": {"$ref": "#/$defs/absolute_path"}
      },
      "required": ["config", "plist", "tools_root"],
      "type": "object"
    },
    "installation": {
      "additionalProperties": false,
      "properties": {
        "instance_rappid": {"$ref": "#/$defs/rappid"},
        "product_rappid": {"$ref": "#/$defs/rappid"},
        "root": {"$ref": "#/$defs/absolute_path"}
      },
      "required": ["root", "product_rappid", "instance_rappid"],
      "type": "object"
    },
    "previous_pages": {
      "additionalProperties": false,
      "properties": {
        "commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "promotion_receipt_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "promotion_run_id": {
          "pattern": "^[0-9]+$",
          "type": "string"
        },
        "tag": {"$ref": "#/$defs/tag"}
      },
      "required": [
        "tag",
        "commit",
        "manifest_sha256",
        "promotion_receipt_sha256",
        "promotion_run_id"
      ],
      "type": "object"
    },
    "release": {
      "additionalProperties": false,
      "properties": {
        "tag": {"$ref": "#/$defs/tag"}
      },
      "required": ["tag"],
      "type": "object"
    },
    "schema": {
      "const": "rapp-private-demo-live-receipt/1.0"
    }
  },
  "required": [
    "schema",
    "controller",
    "installation",
    "imessage",
    "release",
    "previous_pages"
  ],
  "title": "Private mode-0600 demo or live rollback receipt",
  "type": "object"
}
