{
  "$defs": {
    "hex64": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:controller-tombstone:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "identity_hash": {
      "$ref": "#/$defs/hex64"
    },
    "instance_rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
      "type": "string"
    },
    "product_rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
      "type": "string"
    },
    "purged_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    },
    "rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
      "type": "string"
    },
    "schema": {
      "const": "rapp-controller-purge-tombstone/1.0"
    },
    "source_commit": {
      "pattern": "^(?:WORKTREE|[0-9a-f]{40})$",
      "type": "string"
    },
    "source_tree_digest": {
      "$ref": "#/$defs/hex64"
    },
    "transport_generation": {
      "minimum": 1,
      "type": "integer"
    },
    "transport_key_id": {
      "$ref": "#/$defs/hex64"
    }
  },
  "required": [
    "schema",
    "rappid",
    "identity_hash",
    "instance_rappid",
    "product_rappid",
    "purged_at",
    "source_commit",
    "source_tree_digest",
    "transport_key_id",
    "transport_generation"
  ],
  "title": "Permanent controller purge tombstone",
  "type": "object"
}
