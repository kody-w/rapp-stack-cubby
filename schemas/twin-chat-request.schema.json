{
  "$defs": {
    "rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
      "type": "string"
    },
    "timestamp": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:twin-chat-request:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "key_epoch is signed and MUST equal the receiver's current monotonic pairing epoch.",
  "additionalProperties": false,
  "properties": {
    "facets": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 16,
      "type": "array",
      "uniqueItems": true
    },
    "from_rappid": {
      "$ref": "#/$defs/rappid"
    },
    "kind": {
      "const": "say"
    },
    "key_epoch": {
      "maximum": 2147483647,
      "minimum": 1,
      "type": "integer"
    },
    "nonce": {
      "pattern": "^[A-Za-z0-9_-]{22,128}$",
      "type": "string"
    },
    "payload": {
      "$ref": "brainstem-chat-request.schema.json"
    },
    "schema": {
      "const": "rapp-twin-chat/1.0"
    },
    "to_rappid": {
      "$ref": "#/$defs/rappid"
    },
    "utc": {
      "$ref": "#/$defs/timestamp"
    }
  },
  "required": [
    "schema",
    "from_rappid",
    "to_rappid",
    "utc",
    "nonce",
    "key_epoch",
    "kind",
    "payload",
    "facets"
  ],
  "title": "Implemented exact signed twin-chat inner request",
  "type": "object"
}
