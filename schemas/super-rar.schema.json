{
  "$id": "urn:rapp:schema:super-rar:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "entries": {
      "items": {
        "properties": {
          "kind": {
            "enum": [
              "controller-agent",
              "rapplication",
              "release-artifact"
            ]
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "streamable": {
            "type": "boolean"
          }
        },
        "required": [
          "kind",
          "sha256",
          "streamable"
        ],
        "type": "object"
      },
      "minItems": 2,
      "type": "array"
    },
    "release_specific": {
      "type": "boolean"
    },
    "schema": {
      "const": "rapp-super-rar/1.0"
    },
    "streamable_entry_count": {
      "const": 1
    },
    "version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:rc[0-9]+)?$",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "entries",
    "release_specific",
    "streamable_entry_count",
    "version"
  ],
  "title": "SHA-deduplicated RAPP source and artifact index",
  "type": "object"
}
