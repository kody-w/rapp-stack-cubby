{
  "$defs": {
    "relativePath": {
      "not": {
        "pattern": "(^/|(^|/)\\.\\.(/|$)|\\\\)"
      },
      "pattern": "^[A-Za-z0-9._/-]+$",
      "type": "string"
    },
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:cubby:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "controller": {
      "additionalProperties": false,
      "properties": {
        "catalog": {
          "$ref": "#/$defs/relativePath"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "streamable_agent_count": {
          "const": 1
        }
      },
      "required": [
        "catalog",
        "path",
        "sha256",
        "streamable_agent_count"
      ],
      "type": "object"
    },
    "created_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    },
    "display_name": {
      "maxLength": 100,
      "minLength": 1,
      "type": "string"
    },
    "estate": {
      "additionalProperties": false,
      "properties": {
        "anatomy": {
          "items": {
            "enum": [
              "agents",
              "organs",
              "senses",
              "rapplications",
              "neighborhoods",
              "eggs",
              "show-and-tell"
            ]
          },
          "maxItems": 7,
          "minItems": 7,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "anatomy"
      ],
      "type": "object"
    },
    "github_login": {
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,37}[a-z0-9])?$",
      "type": "string"
    },
    "product_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:rc[0-9]+)?$",
      "type": "string"
    },
    "schema": {
      "const": "rapp-cubby/1.0"
    },
    "slug": {
      "pattern": "^[a-z0-9][a-z0-9.-]{0,62}$",
      "type": "string"
    },
    "streamable": {
      "additionalProperties": false,
      "properties": {
        "agents": {
          "const": true
        }
      },
      "required": [
        "agents"
      ],
      "type": "object"
    },
    "what_im_cooking": {
      "maxLength": 280,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema",
    "slug",
    "github_login",
    "display_name",
    "product_version",
    "created_at",
    "what_im_cooking",
    "estate",
    "streamable",
    "controller"
  ],
  "title": "Public RAPP cubby shelf manifest",
  "type": "object"
}
