{
  "$id": "urn:rapp:schema:installed-offline-attestation:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attestation_mode": {
      "const": "offline-self-test"
    },
    "attestation_model": {
      "const": "attestation-self-test/1.0"
    },
    "imessage_sent": {
      "const": false
    },
    "installed_source_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "orphan_count": {
      "const": 0
    },
    "published": {
      "const": false
    },
    "schema": {
      "const": "rapp-installed-offline-attestation/1.0"
    },
    "signed_only": {
      "const": true
    },
    "verified": {
      "const": true
    }
  },
  "required": [
    "schema",
    "verified",
    "attestation_mode",
    "attestation_model",
    "signed_only",
    "installed_source_digest",
    "orphan_count",
    "published",
    "imessage_sent"
  ],
  "title": "Installed-byte offline signed attestation",
  "type": "object"
}
