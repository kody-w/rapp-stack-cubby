{
  "$id": "urn:rapp:schema:installed-offline-attestation:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attestation_mode": {
      "const": "offline-self-test"
    },
    "attestation_model": {
      "const": "attestation-self-test/1.0"
    },
    "diagnostics": {
      "additionalProperties": false,
      "properties": {
        "child_stage": {
          "enum": [
            "not_adopted",
            "adopted",
            "running",
            "attested",
            "stopped",
            "archived",
            "unarchived",
            "purged"
          ]
        },
        "controller_log_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "controller_log_size": {
          "minimum": 0,
          "type": "integer"
        },
        "process_category": {
          "enum": [
            "not_started",
            "running",
            "exited_zero",
            "exited_nonzero",
            "signaled",
            "launch_failed",
            "timed_out",
            "invalid_output",
            "status_unavailable"
          ]
        },
        "process_return_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "stage_code": {
          "enum": [
            "initialization",
            "host_python_validation",
            "install_static_verification",
            "installed_python_probe",
            "controller_auth",
            "controller_spawn",
            "controller_readiness",
            "installed_adoption",
            "child_start",
            "signed_self_test",
            "child_stop",
            "child_archive",
            "child_unarchive",
            "child_status",
            "child_purge",
            "lifecycle_verification",
            "complete"
          ]
        }
      },
      "required": [
        "stage_code",
        "process_return_code",
        "process_category",
        "controller_log_size",
        "controller_log_sha256",
        "child_stage"
      ],
      "type": "object"
    },
    "imessage_sent": {
      "const": false
    },
    "installed_source_digest": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "orphan_count": {
      "anyOf": [
        {
          "const": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "published": {
      "const": false
    },
    "schema": {
      "const": "rapp-installed-offline-attestation/1.0"
    },
    "signed_only": {
      "const": true
    },
    "verified": {
      "type": "boolean"
    }
  },
  "required": [
    "schema",
    "verified",
    "attestation_mode",
    "attestation_model",
    "signed_only",
    "installed_source_digest",
    "orphan_count",
    "published",
    "imessage_sent"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "verified": {
            "const": false
          }
        },
        "required": [
          "verified"
        ]
      },
      "then": {
        "required": [
          "diagnostics"
        ]
      }
    }
  ],
  "title": "Installed-byte offline signed attestation",
  "type": "object"
}
