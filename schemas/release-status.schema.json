{
  "$id": "urn:rapp:schema:release-status:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "release": {
      "const": false
    },
    "schema": {
      "const": "rapp-release-status/1.0"
    },
    "source_commit": {
      "type": "null"
    },
    "status": {
      "const": "pending"
    },
    "tag": {
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[1-9][0-9]*)?$",
      "type": "string"
    },
    "truth": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:rc[0-9]+)?$",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "status",
    "release",
    "version",
    "tag",
    "source_commit",
    "truth"
  ],
  "title": "Current source release truth",
  "type": "object"
}
