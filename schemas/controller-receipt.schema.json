{
  "$defs": {
    "hex64": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:controller-receipt:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "action": {
      "enum": [
        "hatch_repo",
        "adopt_install",
        "start",
        "stop",
        "archive",
        "unarchive",
        "purge",
        "rotate_keys"
      ]
    },
    "created_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    },
    "identity_hash": {
      "$ref": "#/$defs/hex64"
    },
    "instance_rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,62}:[0-9a-f]{64}$",
      "type": "string"
    },
    "product_rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,62}:[0-9a-f]{64}$",
      "type": "string"
    },
    "rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,62}:[0-9a-f]{64}$",
      "type": "string"
    },
    "receipt_id": {
      "pattern": "^[0-9a-f]{32}$",
      "type": "string"
    },
    "release_manifest_sha256": {
      "anyOf": [
        {
          "$ref": "#/$defs/hex64"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema": {
      "const": "rapp-controller-receipt/1.0"
    },
    "source_commit": {
      "pattern": "^(?:WORKTREE|[0-9a-f]{40})$",
      "type": "string"
    },
    "source_tree_digest": {
      "$ref": "#/$defs/hex64"
    },
    "status": {
      "const": "completed"
    }
  },
  "required": [
    "schema",
    "receipt_id",
    "action",
    "rappid",
    "identity_hash",
    "instance_rappid",
    "product_rappid",
    "created_at",
    "source_commit",
    "source_tree_digest",
    "release_manifest_sha256",
    "status"
  ],
  "title": "Sanitized private controller lifecycle receipt",
  "type": "object"
}
