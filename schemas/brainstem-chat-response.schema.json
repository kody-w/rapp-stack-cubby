{
  "$id": "urn:rapp:schema:brainstem-chat-response:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "examples": [
    {
      "agent_logs": "",
      "model": "configured-model",
      "requested_model": "configured-model",
      "response": "synthetic response",
      "session_id": "synthetic-session",
      "voice_mode": false
    }
  ],
  "properties": {
    "agent_logs": {
      "maxLength": 1048576,
      "type": "string"
    },
    "model": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    },
    "requested_model": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    },
    "response": {
      "maxLength": 1048576,
      "type": "string"
    },
    "session_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "type": "string"
    },
    "voice_mode": {
      "type": "boolean"
    }
  },
  "required": [
    "response",
    "session_id",
    "agent_logs",
    "voice_mode",
    "model",
    "requested_model"
  ],
  "title": "Implemented local brainstem chat response",
  "type": "object"
}
