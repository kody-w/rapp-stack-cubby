{
  "$defs": {
    "hex64": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "jwk": {
      "additionalProperties": false,
      "properties": {
        "crv": {
          "const": "P-256"
        },
        "kty": {
          "const": "EC"
        },
        "x": {
          "pattern": "^[A-Za-z0-9_-]{43}$",
          "type": "string"
        },
        "y": {
          "pattern": "^[A-Za-z0-9_-]{43}$",
          "type": "string"
        }
      },
      "required": [
        "kty",
        "crv",
        "x",
        "y"
      ],
      "type": "object"
    },
    "rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:twin-chat-pairing:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "generation and key_epoch MUST be equal and increase monotonically on rotation.",
  "additionalProperties": false,
  "properties": {
    "child_key_id": {
      "$ref": "#/$defs/hex64"
    },
    "child_public_jwk": {
      "$ref": "#/$defs/jwk"
    },
    "controller_key_id": {
      "$ref": "#/$defs/hex64"
    },
    "controller_public_jwk": {
      "$ref": "#/$defs/jwk"
    },
    "controller_rappid": {
      "$ref": "#/$defs/rappid"
    },
    "generation": {
      "minimum": 1,
      "type": "integer"
    },
    "key_epoch": {
      "maximum": 2147483647,
      "minimum": 1,
      "type": "integer"
    },
    "paired_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    },
    "schema": {
      "const": "rapp-twin-chat-pairing/1.0"
    },
    "twin_rappid": {
      "$ref": "#/$defs/rappid"
    }
  },
  "required": [
    "schema",
    "twin_rappid",
    "controller_rappid",
    "controller_key_id",
    "controller_public_jwk",
    "child_key_id",
    "child_public_jwk",
    "generation",
    "key_epoch",
    "paired_at"
  ],
  "title": "Private controller-child transport pairing",
  "type": "object"
}
