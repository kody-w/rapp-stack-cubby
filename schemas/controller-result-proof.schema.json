{
  "$defs": {
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:controller-result-proof:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "action": {
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "type": "string"
    },
    "algorithm": {
      "const": "sha256"
    },
    "child_response_sha256": {
      "$ref": "#/$defs/digest"
    },
    "controller_result_sha256": {
      "$ref": "#/$defs/digest"
    },
    "instance_rappid": {
      "oneOf": [
        {
          "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "key_epoch": {
      "oneOf": [
        {
          "maximum": 2147483647,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "request_sha256": {
      "$ref": "#/$defs/digest"
    },
    "result_sha256": {
      "$ref": "#/$defs/digest"
    },
    "schema": {
      "const": "rapp-controller-result-proof/1.0"
    },
    "signed_twin_chat_status": {
      "enum": [
        "verified",
        "rejected",
        "not_applicable"
      ]
    },
    "signed_twin_chat_verified": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "ok",
        "rejected"
      ]
    },
    "tool": {
      "const": "RappStackCubbyController"
    }
  },
  "required": [
    "schema",
    "algorithm",
    "tool",
    "action",
    "request_sha256",
    "result_sha256",
    "controller_result_sha256",
    "child_response_sha256",
    "signed_twin_chat_verified",
    "signed_twin_chat_status",
    "instance_rappid",
    "key_epoch",
    "status"
  ],
  "title": "Content-free deterministic controller result proof",
  "type": "object"
}
