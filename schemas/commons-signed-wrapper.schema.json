{
  "$defs": {
    "jwk": {
      "additionalProperties": false,
      "properties": {
        "crv": {
          "const": "P-256"
        },
        "kty": {
          "const": "EC"
        },
        "x": {
          "pattern": "^[A-Za-z0-9_-]{43}$",
          "type": "string"
        },
        "y": {
          "pattern": "^[A-Za-z0-9_-]{43}$",
          "type": "string"
        }
      },
      "required": [
        "kty",
        "crv",
        "x",
        "y"
      ],
      "type": "object"
    },
    "rappid": {
      "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:rapp:schema:commons-signed-wrapper:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "String/byte wire input MUST already equal canonical compact sorted-key UTF-8 JSON. sig is canonical unpadded 64-byte low-S P-256 P1363, not DER.",
  "additionalProperties": false,
  "properties": {
    "alg": {
      "const": "ecdsa-p256"
    },
    "body": {
      "$ref": "twin-chat-request.schema.json"
    },
    "from": {
      "$ref": "#/$defs/rappid"
    },
    "key_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "kind": {
      "const": "say"
    },
    "pub": {
      "$ref": "#/$defs/jwk"
    },
    "schema": {
      "const": "rapp-commons-event/1.0"
    },
    "sig": {
      "pattern": "^[A-Za-z0-9_-]{86}$",
      "type": "string"
    },
    "ts": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "from",
    "pub",
    "alg",
    "ts",
    "kind",
    "body",
    "key_id",
    "sig"
  ],
  "title": "Implemented ECDSA P-256 Commons twin-chat relay wrapper",
  "type": "object"
}
