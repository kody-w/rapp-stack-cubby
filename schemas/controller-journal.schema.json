{
  "$id": "urn:rapp:schema:controller-journal:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "action": {
      "enum": [
        "hatch_repo",
        "adopt_install",
        "start",
        "stop",
        "archive",
        "unarchive",
        "purge",
        "rotate_keys",
        "chat",
        "self_test"
      ]
    },
    "identity_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "idempotency_key_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "receipt_id": {
      "pattern": "^[0-9a-f]{32}$",
      "type": "string"
    },
    "phase": {
      "minLength": 1,
      "type": "string"
    },
    "request_digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "signed_request": {
      "additionalProperties": false,
      "properties": {
        "child_key_id": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "controller_key_id": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "created_at": {
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
          "type": "string"
        },
        "generation": {
          "minimum": 1,
          "type": "integer"
        },
        "key_epoch": {
          "maximum": 2147483647,
          "minimum": 1,
          "type": "integer"
        },
        "nonce": {
          "pattern": "^[A-Za-z0-9_-]{22,128}$",
          "type": "string"
        },
        "request_digest": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "schema": {
          "const": "rapp-controller-signed-request/1.0"
        },
        "state": {
          "enum": [
            "prepared",
            "dispatch_intent",
            "response_verified"
          ]
        },
        "target_rappid": {
          "pattern": "^rappid:@[a-z0-9][a-z0-9-]{0,62}/[a-z0-9][a-z0-9-]{0,127}:[0-9a-f]{64}$",
          "type": "string"
        },
        "wire_b64": {
          "pattern": "^[A-Za-z0-9_-]+$",
          "type": "string"
        },
        "wire_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "schema",
        "wire_b64",
        "wire_sha256",
        "nonce",
        "request_digest",
        "target_rappid",
        "controller_key_id",
        "child_key_id",
        "key_epoch",
        "generation",
        "state",
        "created_at"
      ],
      "type": "object"
    },
    "signed_response": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "additionalProperties": false,
          "properties": {
            "schema": {
              "const": "rapp-controller-signed-response/1.0"
            },
            "status": {
              "enum": [
                "ok",
                "rejected"
              ]
            },
            "verified_at": {
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
              "type": "string"
            },
            "wire_b64": {
              "pattern": "^[A-Za-z0-9_-]+$",
              "type": "string"
            },
            "wire_sha256": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            }
          },
          "required": [
            "schema",
            "wire_b64",
            "wire_sha256",
            "status",
            "verified_at"
          ],
          "type": "object"
        }
      ]
    },
    "owner_pid": {
      "minimum": 2,
      "type": "integer"
    },
    "owner_start_identity": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "lease_expires_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    },
    "schema": {
      "const": "rapp-controller-journal/1.0"
    },
    "status": {
      "enum": [
        "in_progress",
        "completed",
        "failed"
      ]
    },
    "updated_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "action",
    "identity_hash",
    "idempotency_key_sha256",
    "status",
    "phase",
    "owner_pid",
    "owner_start_identity",
    "lease_expires_at",
    "request_digest",
    "updated_at"
  ],
  "title": "Private controller transition journal",
  "type": "object"
}
