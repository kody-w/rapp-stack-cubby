{
  "$id": "urn:rapp:schema:agent-manifest:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "examples": [
    {
      "actions": [
        "inspect"
      ],
      "capability_ids": [
        "governance.authority-order"
      ],
      "dependencies": [
        "python-stdlib",
        "BasicAgent"
      ],
      "description": "Inspect normalized local authority.",
      "enabled_by_default": true,
      "mutability": "read_only",
      "name": "SyntheticAgent",
      "provenance": "original_new",
      "schema": "rapp-agent/1.0",
      "version": "1.0.0"
    }
  ],
  "properties": {
    "actions": {
      "items": {
        "pattern": "^[a-z][a-z0-9_]{0,63}$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "capability_ids": {
      "items": {
        "pattern": "^[a-z][a-z0-9-]*\\.[a-z0-9][a-z0-9.-]*$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "dependencies": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "description": {
      "maxLength": 240,
      "minLength": 1,
      "type": "string"
    },
    "enabled_by_default": {
      "type": "boolean"
    },
    "mutability": {
      "enum": [
        "read_only",
        "guarded_generated_files",
        "guarded_local_state",
        "guarded_local_lifecycle"
      ]
    },
    "name": {
      "pattern": "^[A-Z][A-Za-z0-9]{0,63}$",
      "type": "string"
    },
    "provenance": {
      "enum": [
        "generated_local",
        "original_new"
      ]
    },
    "schema": {
      "const": "rapp-agent/1.0"
    },
    "version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "name",
    "version",
    "description",
    "actions",
    "capability_ids",
    "mutability",
    "enabled_by_default",
    "provenance",
    "dependencies"
  ],
  "title": "RAPP actual-agent manifest",
  "type": "object"
}
