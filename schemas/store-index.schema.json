{
  "$id": "urn:rapp:schema:store-index:1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "applications": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "application_id": {
            "const": "rapp-stack"
          },
          "application_manifest_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "application_manifest_size": {
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [
          "application_id",
          "application_manifest_sha256",
          "application_manifest_size"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "published": {
      "const": false
    },
    "release_specific": {
      "type": "boolean"
    },
    "schema": {
      "const": "rapp-store-index/1.0"
    },
    "version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:rc[0-9]+)?$",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "applications",
    "published",
    "release_specific",
    "version"
  ],
  "title": "Local deterministic RAPP Store intake index",
  "type": "object"
}
